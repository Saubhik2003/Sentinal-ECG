# Sentinel Environment Configuration
# Copy this to .env and update with your actual values

# Application
FLASK_ENV=development
FLASK_APP=backend_api.py
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ACCESS_TOKEN_EXPIRES=86400  # 24 hours in seconds

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=sentinel_health

# CORS Settings
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# Email Configuration (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=sentinel@example.com
SMTP_PASSWORD=your-email-password
SMTP_USE_TLS=True

# Twilio (for SMS alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Emergency Services
EMERGENCY_HOTLINE=911
HOSPITAL_CONTACT=+1-555-SENTINEL

# AI Model Configuration
AI_MODEL_PATH=./models/
ECG_MODEL_VERSION=v1.0
STRESS_MODEL_VERSION=v1.0
SLEEP_MODEL_VERSION=v1.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/sentinel.log

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# Security
SESSION_TIMEOUT=3600  # 1 hour
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300  # 5 minutes

# Features
ENABLE_EMAIL_ALERTS=True
ENABLE_SMS_ALERTS=True
ENABLE_PUSH_NOTIFICATIONS=False
ENABLE_AI_CHATBOT=True

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # per hour

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=60  # seconds
